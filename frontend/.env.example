NEXT_PUBLIC_API_BASE_URL=https://your-api-gateway-id.execute-api.eu-west-1.amazonaws.com/prod
NEXT_PUBLIC_WS_BASE_URL=wss://your-websocket-api-id.execute-api.eu-west-1.amazonaws.com/prod

# Discord OAuth2
NEXT_PUBLIC_DISCORD_CLIENT_ID=your_discord_client_id
NEXT_PUBLIC_DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback

# Canvas settings
NEXT_PUBLIC_CANVAS_COOLDOWN_MS=3000
